{
  "name": "rdesk-electron-ui",
  "version": "0.1.0",
  "description": "RustDesk Electron UI PoC - Desktop remote control interface",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build:native": "cd native && napi build --platform --release",
    "build:native:debug": "cd native && napi build --platform",
    "dev": "electron-vite dev",
    "dev:full": "npm run build:native:debug && electron-vite dev",
    "build": "npm run build:native && electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
